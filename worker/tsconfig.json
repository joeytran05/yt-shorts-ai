{
	"compilerOptions": {
		"target": "ES2020",
		"module": "commonjs",
		"moduleResolution": "node",
		"outDir": "./dist",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"jsx": "react",
		"baseUrl": ".",
		"paths": { "@/*": ["../src/*"] }
	},
	"include": ["./**/*.ts", "./**/*.tsx", "../src/types/**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
